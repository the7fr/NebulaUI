    function Window:SaveConfig(name)
        local data = {}
        for flag, obj in pairs(self.Flags) do
            local ok, v = pcall(obj.Get)
            if ok then
                if typeof(v) == "Color3" then
                    data[flag] = {__type="Color3", v.R, v.G, v.B}
                elseif typeof(v) == "EnumItem" then
                    data[flag] = {__type="Enum", v.Name}
                else
                    data[flag] = v
                end
            end
        end
        local ok2 = pcall(function()
            if not isfolder(GetConfigFolder()) then makefolder(GetConfigFolder()) end
            writefile(GetConfigFolder().."/"..name..".json", HttpService:JSONEncode(data))
        end)
        return ok2
    end

    function Window:LoadConfig(name)
        local ok, content = pcall(readfile, GetConfigFolder().."/"..name..".json")
        if not ok then return false end
        local ok2, data = pcall(function() return HttpService:JSONDecode(content) end)
        if not ok2 then return false end
        for flag, v in pairs(data) do
            local obj = self.Flags[flag]
            if obj then
                if type(v) == "table" and v.__type == "Color3" then
                    pcall(obj.Set, Color3.new(v[1], v[2], v[3]))
                elseif type(v) == "table" and v.__type == "Enum" then
                    pcall(obj.Set, Enum.KeyCode[v[1]])
                else
                    pcall(obj.Set, v)
                end
            end
        end
        return true
    end

    function Window:ListConfigs()
        local list = {}
        pcall(function()
            if isfolder(GetConfigFolder()) then
                for _, f in ipairs(listfiles(GetConfigFolder())) do
                    local nm = f:match("([^/\\]+)%.json$")
                    if nm then table.insert(list, nm) end
                end
            end
        end)
        return list
    end

    function Window:DeleteConfig(name)
        pcall(delfile, GetConfigFolder().."/"..name..".json")
    end

