    local function FireNotif(ncfg)
        ncfg = ncfg or {}
        local typeColors = {
            info    = Theme.Blue,
            success = Theme.Green,
            warning = Theme.Amber,
            error   = Theme.Red,
        }
        local tc = typeColors[ncfg.Type or "info"] or Theme.Blue
        local dur = ncfg.Duration or 4
        local cardH = (ncfg.Message and 62 or 40)

        local Toast = New("Frame", {
            Size = UDim2.new(0, NOTIF_W, 0, cardH),
            Position = UDim2.new(1, NOTIF_W+24, 1, -cardH),
            AnchorPoint = Vector2.new(0, 1),
            BackgroundColor3 = Theme.Surface,
            BorderSizePixel = 0,
            ZIndex = 200,
            ClipsDescendants = true,
            Parent = Gui,
        })
        Corner(14, Toast)
        Stroke(Theme.Border, 1, Toast)

        local AccentBar = New("Frame", {
            Size = UDim2.new(0,3,1,-10), Position = UDim2.new(0,5,0,5),
            BackgroundColor3 = tc, BorderSizePixel = 0,
            ZIndex = 201, Parent = Toast,
        })
        Corner(2, AccentBar)

        local IconCircle = New("Frame", {
            Size = UDim2.new(0,26,0,26), Position = UDim2.new(0,16,0,13),
            BackgroundColor3 = tc, BackgroundTransparency = 0.78,
            BorderSizePixel = 0, ZIndex = 201, Parent = Toast,
        })
        Corner(13, IconCircle)
        local IconImg = New("ImageLabel", {
            Size = UDim2.new(0,14,0,14), Position = UDim2.new(0,6,0,6),
            BackgroundTransparency = 1, ImageColor3 = tc,
            ZIndex = 202, Parent = IconCircle,
        })
        if ncfg.Icon then
            ApplyIcon(IconImg, ncfg.Icon, ncfg.IconSource or "Phosphor")
        else
            local typeIcons = { info = "info", success = "check-circle", warning = "warning", error = "x-circle" }
            ApplyIcon(IconImg, typeIcons[ncfg.Type or "info"], "Phosphor")
        end

        New("TextLabel", {
            Text = ncfg.Title or "Notification",
            Size = UDim2.new(1,-94,0,18), Position = UDim2.new(0,54,0,ncfg.Message and 11 or 11),
            BackgroundTransparency = 1, TextColor3 = Theme.Text,
            Font = Theme.FontBold, TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            ZIndex = 201, Parent = Toast,
        })

        if ncfg.Message then
            New("TextLabel", {
                Text = ncfg.Message,
                Size = UDim2.new(1,-72,0,30), Position = UDim2.new(0,54,0,30),
                BackgroundTransparency = 1, TextColor3 = Theme.Muted,
                Font = Theme.Font, TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true, ZIndex = 201, Parent = Toast,
            })
        end

        local CloseX = New("TextButton", {
            Text = "x", Size = UDim2.new(0,20,0,20),
            Position = UDim2.new(1,-26,0,10),
            BackgroundTransparency = 1, TextColor3 = Theme.Dim,
            Font = Theme.FontBold, TextSize = 12,
            ZIndex = 202, Parent = Toast,
        })

        local ProgTrack = New("Frame", {
            Size = UDim2.new(1,-10,0,3), Position = UDim2.new(0,5,1,-6),
            BackgroundColor3 = Theme.Surface3, BorderSizePixel = 0,
            ZIndex = 201, Parent = Toast,
        })
        Corner(2, ProgTrack)
        local ProgFill = New("Frame", {
            Size = UDim2.new(1,0,1,0), BackgroundColor3 = tc,
            BorderSizePixel = 0, ZIndex = 202, Parent = ProgTrack,
        })
        Corner(2, ProgFill)

        local slot = {frame=Toast, height=cardH}
        table.insert(_notifStack, slot)

        local bottomY = -14
        for i = #_notifStack, 1, -1 do
            local s = _notifStack[i]
            local targetPos = UDim2.new(1, -14-NOTIF_W, 1, bottomY - s.height)
            if i == #_notifStack then
                Tween(s.frame, {Position = targetPos}, 0.3, Enum.EasingStyle.Back)
            else
                Tween(s.frame, {Position = targetPos}, 0.2)
            end
            bottomY = bottomY - s.height - 10
        end

        Tween(ProgFill, {Size = UDim2.new(0,0,1,0)}, dur, Enum.EasingStyle.Linear)

        local _dismissed = false
        local function Dismiss()
            if _dismissed then return end
            _dismissed = true
            for i, s in ipairs(_notifStack) do
                if s == slot then table.remove(_notifStack, i) break end
            end
            local by = -14
            for i = #_notifStack, 1, -1 do
                local s = _notifStack[i]
                Tween(s.frame, {Position=UDim2.new(1,-14-NOTIF_W,1,by-s.height)}, 0.18)
                by = by - s.height - 10
            end
            Tween(Toast, {Position=UDim2.new(1,NOTIF_W+24,Toast.Position.Y.Scale,Toast.Position.Y.Offset)}, 0.2)
            task.wait(0.22) Toast:Destroy()
        end

        CloseX.MouseButton1Click:Connect(Dismiss)
        task.delay(dur, Dismiss)
    end

