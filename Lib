                Size=UDim2.new(1,0,0,34),
                BackgroundColor3=Theme.Surface, BorderSizePixel=0,
                LayoutOrder=NO(), Parent=Page,
            })
            Corner(8,Row) Stroke(Theme.Border,1,Row)
            local ico = RowIconImg(Row, cfg.Icon, cfg.IconSource)
            local tx  = TextX(ico.Visible)
            New("TextLabel",{
                Text=cfg.Label or "Keybind",
                Size=UDim2.new(1,-106,1,0), Position=UDim2.new(0,tx,0,0),
                BackgroundTransparency=1, TextColor3=Theme.Text,
                Font=Theme.Font, TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left, Parent=Row,
            })
            local KBtn = New("TextButton",{
                Text=curKey.Name~="Unknown" and curKey.Name or "None",
                Size=UDim2.new(0,84,0,22), Position=UDim2.new(1,-92,0.5,-11),
                BackgroundColor3=Theme.Surface3, BorderSizePixel=0,
                TextColor3=Theme.Accent, Font=Theme.FontMono, TextSize=10,
                ZIndex=2, Parent=Row,
            })
            Corner(5,KBtn) Stroke(Theme.Border2,1,KBtn)

            local kbEntry = action and Window._keybinds[#Window._keybinds] or nil

            KBtn.MouseButton1Click:Connect(function()
                if listen then return end
                listen=true
                KBtn.Text="..."
                Tween(KBtn,{BackgroundColor3=Theme.Accent,TextColor3=Color3.new(1,1,1)},0.1)
            end)
            UserInputService.InputBegan:Connect(function(input, gp)
                if not listen then return end
                if input.UserInputType==Enum.UserInputType.Keyboard then
                    listen=false
                    curKey=input.KeyCode
                    KBtn.Text=curKey.Name
                    Tween(KBtn,{BackgroundColor3=Theme.Surface3,TextColor3=Theme.Accent},0.1)
                    if kbEntry then kbEntry.key=curKey end
                    if cfg.Callback then pcall(cfg.Callback, curKey) end
                end
            end)
            local obj = {
                GetValue=function() return curKey end,
                SetValue=function(_,k)
                    curKey=k KBtn.Text=k.Name
                    if kbEntry then kbEntry.key=k end
                end,
            }
            RegisterFlag(Tab._window, cfg, obj, "GetValue", "SetValue")
            return obj
        end

        function Tab:Notify(cfg)
            FireNotif(cfg)
        end

        return Tab
    end

    function Window:CreateInfoTab(label)
        local Tab = self:CreateTab(label or "Info", {Icon="info", IconSource="Phosphor", Pinned=true})
        local Page = Tab._page

        local Card = New("Frame", {
            Size = UDim2.new(1,0,0,84), BackgroundColor3 = Theme.Surface,
            BorderSizePixel = 0, LayoutOrder = 0, Parent = Page,
        })
        Corner(10, Card) Stroke(Theme.Border,1,Card)
        local Thumb = New("ImageLabel", {
            Size = UDim2.new(0,62,0,62), Position = UDim2.new(0,11,0.5,-31),
            BackgroundColor3 = Theme.Surface3, BorderSizePixel = 0,
            Image = gameThumb, Parent = Card,
        })
        Corner(9, Thumb) Stroke(Theme.Border2,1,Thumb)
        New("TextLabel", {
            Text = gameName, Size = UDim2.new(1,-86,0,18), Position = UDim2.new(0,84,0,18),
            BackgroundTransparency = 1, TextColor3 = Theme.Text,
            Font = Theme.FontBold, TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd, Parent = Card,
        })
        New("TextLabel", {
            Text = "Place ID "..tostring(placeId), Size = UDim2.new(1,-86,0,14), Position = UDim2.new(0,84,0,38),
            BackgroundTransparency = 1, TextColor3 = Theme.Dim,
            Font = Theme.FontMono, TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = Card,
        })

        local function Row(label2, value2, order, copyable)
            local R = New("Frame", { Size = UDim2.new(1,0,0,30), BackgroundColor3 = Theme.Surface, BorderSizePixel = 0, LayoutOrder = order, Parent = Page })
            Corner(8,R) Stroke(Theme.Border,1,R)
            New("TextLabel", { Text = label2, Size = UDim2.new(0.5,-12,1,0), Position = UDim2.new(0,12,0,0), BackgroundTransparency=1, TextColor3=Theme.Muted, Font=Theme.Font, TextSize=11, TextXAlignment=Enum.TextXAlignment.Left, Parent=R })
            local valW = copyable and 0.5-30 or 0.5-12
            local V = New("TextLabel", { Text = value2, Size = UDim2.new(0.5,copyable and -34 or -12,1,0), Position = UDim2.new(0.5,0,0,0), BackgroundTransparency=1, TextColor3=Theme.Text, Font=Theme.FontMono, TextSize=11, TextXAlignment=Enum.TextXAlignment.Right, TextTruncate=Enum.TextTruncate.AtEnd, Parent=R })
            if copyable then
                local CopyBtn = New("TextButton", {
                    Text="", Size=UDim2.new(0,20,0,20), Position=UDim2.new(1,-22,0.5,-10),
                    BackgroundTransparency=1, AutoButtonColor=false, ZIndex=2, Parent=R,
                })
                local cIco = New("ImageLabel", {
                    Size=UDim2.new(0,13,0,13), Position=UDim2.new(0.5,-6,0.5,-6),
                    BackgroundTransparency=1, ImageColor3=Theme.Muted, Parent=CopyBtn,
                })
                ApplyIcon(cIco, "copy", "Phosphor")
                CopyBtn.MouseEnter:Connect(function() TintIcon(cIco, Theme.Text) end)
                CopyBtn.MouseLeave:Connect(function() TintIcon(cIco, Theme.Muted) end)
                CopyBtn.MouseButton1Click:Connect(function()
                    local ok = pcall(function() setclipboard(value2) end)
                    Window:Notify({
                        Title = ok and "Copied" or "Copy Failed",
                        Message = ok and (label2.." copied to clipboard") or "Clipboard access unavailable",
                        Type = ok and "success" or "error",
                    })
                end)
            end
            return V
        end

        local jobIdStr = game.JobId ~= "" and game.JobId or "Studio"
        Row("Job ID", jobIdStr, 1, true)
        Row("Players", tostring(#Players:GetPlayers()).."/"..tostring(Players.MaxPlayers), 2)
        Row("Display Name", displayName, 3)
        Row("Username", "@"..username, 4)
        Row("User ID", tostring(userId), 5)
        local ok, age = pcall(function() return LocalPlayer.AccountAge end)
        Row("Account Age", (ok and tostring(age) or "?").." days", 6)
        local ok2, membership = pcall(function() return LocalPlayer.MembershipType.Name end)
        Row("Membership", ok2 and membership or "Unknown", 7)
        local FpsVal = Row("FPS", "0", 8)
        local PingVal = Row("Ping", "0 ms", 9)

        local _fpsAccum, _fpsCount = 0, 0
        RunService.Heartbeat:Connect(function(dt)
            _fpsAccum += dt
            _fpsCount += 1
            if _fpsAccum >= 0.5 then
                FpsVal.Text = tostring(math.floor(_fpsCount/_fpsAccum))
                _fpsAccum, _fpsCount = 0, 0
            end
        end)
        task.spawn(function()
            while Gui.Parent do
                local ok3, ping = pcall(function()
                    return LocalPlayer:GetNetworkPing() * 1000
                end)
                if ok3 then PingVal.Text = tostring(math.floor(ping)).." ms" end
                task.wait(1)
            end
        end)

        return Tab
    end

    function Window:CreateConfigTab(label)
        local Tab = self:CreateTab(label or "Configs", {Icon="floppy-disk", IconSource="Phosphor", Pinned=true})
        Tab:AddSection("Save Config")
        local nameInput = Tab:AddInput({Label="Config Name", Placeholder="my-config"})
        Tab:AddButton({Text="Save Config", Icon="download-simple", IconSource="Phosphor", Callback=function()
            local n = nameInput:GetValue()
            if n and n ~= "" then
                if self:SaveConfig(n) then
                    self:Notify({Title="Config Saved", Message="Saved as "..n, Type="success"})
                else
                    self:Notify({Title="Save Failed", Message="Could not write file", Type="error"})
                end
            end
        end})
        Tab:AddSeparator()
        Tab:AddSection("Load Config")
        local dd = Tab:AddDropdown({Label="Saved Configs", Options=self:ListConfigs()})
        Tab:AddButton({Text="Refresh List", Icon="arrows-clockwise", IconSource="Phosphor", Callback=function()
            dd:SetOptions(self:ListConfigs())
        end})
        Tab:AddButton({Text="Load Config", Icon="upload-simple", IconSource="Phosphor", Callback=function()
            local n = dd:GetValue()
            if n and n ~= "" then
                if self:LoadConfig(n) then
                    self:Notify({Title="Config Loaded", Message=n, Type="success"})
                else
                    self:Notify({Title="Load Failed", Message=n, Type="error"})
                end
            end
        end})
        Tab:AddButton({Text="Delete Config", Icon="trash", IconSource="Phosphor", Callback=function()
            local n = dd:GetValue()
            if n and n ~= "" then
                self:DeleteConfig(n)
                dd:SetOptions(self:ListConfigs())
                self:Notify({Title="Config Deleted", Message=n, Type="warning"})
            end
        end})
        return Tab
    end

    do
        local Tab = self:CreateTab("Settings", {Icon="gear-six", IconSource="Phosphor", Pinned=true, PinOrder=9999})
        local Page = Tab._page

        Tab:AddSection("Appearance")
        local SwatchRow = New("Frame", { Size=UDim2.new(1,0,0,28), BackgroundTransparency=1, LayoutOrder=999, Parent=Page })
        New("UIListLayout", { Padding=UDim.new(0,8), FillDirection=Enum.FillDirection.Horizontal, SortOrder=Enum.SortOrder.LayoutOrder, Parent=SwatchRow })
        local _themeSwatchRings = {}
        for _, themeName in ipairs(Window:GetThemeNames()) do
            local sw = New("TextButton", {
                Text = "", Size = UDim2.new(0,26,0,26),
                BackgroundColor3 = Themes[themeName].Accent,
                BorderSizePixel = 0, AutoButtonColor = false,
                Parent = SwatchRow,
            })
            Corner(13, sw)
            local ring = Stroke(themeName == _currentThemeName and Color3.new(1,1,1) or Theme.Border, themeName == _currentThemeName and 2 or 1, sw)
            _themeSwatchRings[themeName] = ring
            sw.MouseButton1Click:Connect(function()
                Window:SetTheme(themeName)
                for tn, r in pairs(_themeSwatchRings) do
                    r.Color = (tn == themeName) and Color3.new(1,1,1) or Theme.Border
                    r.Thickness = (tn == themeName) and 2 or 1
                end
            end)
        end

        Tab:AddSeparator()
        Tab:AddSection("Behavior")

        local KeybindRow = New("Frame", {
            Size = UDim2.new(1,0,0,34), BackgroundColor3 = Theme.Surface,
            BorderSizePixel = 0, LayoutOrder = 1001, Parent = Page,
        })
        Corner(8, KeybindRow) Stroke(Theme.Border, 1, KeybindRow)
        New("TextLabel", {
            Text = "Toggle UI Keybind", Size = UDim2.new(1,-96,1,0), Position = UDim2.new(0,14,0,0),
            BackgroundTransparency = 1, TextColor3 = Theme.Text,
            Font = Theme.Font, TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left, Parent = KeybindRow,
        })
        local ToggleKeyBtn = New("TextButton", {
            Text = _toggleUIKey.Name,
            Size = UDim2.new(0,84,0,22), Position = UDim2.new(1,-92,0.5,-11),
            BackgroundColor3 = Theme.Surface3, BorderSizePixel = 0,
            TextColor3 = Theme.Accent, Font = Theme.FontMono, TextSize = 10,
            AutoButtonColor = false, Parent = KeybindRow,
        })
        Corner(5, ToggleKeyBtn) Stroke(Theme.Border2, 1, ToggleKeyBtn)
        ToggleKeyBtn.MouseButton1Click:Connect(function()
            if _listeningForToggle then return end
            _listeningForToggle = true
            ToggleKeyBtn.Text = "..."
            Tween(ToggleKeyBtn, {BackgroundColor3=Theme.Accent, TextColor3=Color3.new(1,1,1)}, 0.1)
        end)
        UserInputService.InputBegan:Connect(function(input, gp)
            if _listeningForToggle and input.UserInputType == Enum.UserInputType.Keyboard then
                _listeningForToggle = false
                _toggleUIKey = input.KeyCode
                ToggleKeyBtn.Text = _toggleUIKey.Name
                Tween(ToggleKeyBtn, {BackgroundColor3=Theme.Surface3, TextColor3=Theme.Accent}, 0.1)
            end
        end)

        Tab:AddParagraph({
            Title = "About",
            Content = Title.." — change the accent theme above, or rebind the key that shows/hides the whole interface.",
        })
    end

    return Window
end

return NebulaHub
