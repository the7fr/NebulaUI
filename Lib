local function RegisterFlag(window, cfg, obj, getKey, setKey)
    if cfg and cfg.Flag and window then
        window.Flags[cfg.Flag] = {
            Get = function() return obj[getKey](obj) end,
            Set = function(v) obj[setKey](obj, v) end,
        }
    end
end

