    local function FireNotif(ncfg)
        ncfg = ncfg or {}
        local typeColors = {
            info    = Theme.Blue,
            success = Theme.Green,
            warning = Theme.Amber,
            error   = Theme.Red,
        }
        local tc = typeColors[ncfg.Type or "info"] or Theme.Blue
        local dur = ncfg.Duration or 4

        local cardH = NOTIF_HEADER_H + (ncfg.Message and 46 or 22)

        local Toast = New("Frame", {
            Size = UDim2.new(0, NOTIF_W, 0, cardH),
            Position = UDim2.new(1, NOTIF_W+24, 1, -cardH),
            AnchorPoint = Vector2.new(0, 1),
            BackgroundColor3 = Theme.Surface,
            BackgroundTransparency = 0.02,
            BorderSizePixel = 0,
            ZIndex = 200,
            ClipsDescendants = true,
            Parent = Gui,
        })
        Corner(16, Toast)
        Stroke(Theme.Border, 1, Toast)

        -- Soft colored glow behind the card (same asset as the main window glow)
        local NGlow = New("ImageLabel", {
            Size = UDim2.new(1,40,1,40), Position = UDim2.new(0,-20,0,-20),
            BackgroundTransparency = 1,
            Image = "rbxassetid://6015897843",
            ImageColor3 = tc, ImageTransparency = 0.82,
            ZIndex = 199, Parent = Toast,
        })

        -- Colored top edge (clipped to the card's rounded corners)
        New("Frame", {
            Size = UDim2.new(1,0,0,3), Position = UDim2.new(0,0,0,0),
            BackgroundColor3 = tc, BorderSizePixel = 0,
            ZIndex = 201, Parent = Toast,
        })

        -- ── Header strip: icon badge + title only — the player's headshot
        -- and username now live in a small pill that floats just above the
        -- toast (built below), instead of crowding the header.
        local Header = New("Frame", {
            Size = UDim2.new(1,0,0,NOTIF_HEADER_H), Position = UDim2.new(0,0,0,3),
            BackgroundTransparency = 1, ZIndex = 202, Parent = Toast,
        })

        local IconCircle = New("Frame", {
            Size = UDim2.new(0,24,0,24), Position = UDim2.new(0,10,0.5,-12),
            BackgroundColor3 = tc, BackgroundTransparency = 0.76,
            BorderSizePixel = 0, ZIndex = 203, Parent = Header,
        })
        Corner(12, IconCircle)
        local IconImg = New("ImageLabel", {
            Size = UDim2.new(0,14,0,14), Position = UDim2.new(0,5,0,5),
            BackgroundTransparency = 1, ImageColor3 = tc,
            Visible = false, ZIndex = 204, Parent = IconCircle,
        })
        if ncfg.Icon then
            ApplyIcon(IconImg, ncfg.Icon, ncfg.IconSource or "Symbols")
        else
            local typeIcons = {
                info = "info", success = "check_circle",
                warning = "warning", error = "error",
            }
            local defIcon = typeIcons[ncfg.Type or "info"]
            if defIcon then ApplyIcon(IconImg, defIcon, "Material") end
        end

        New("TextLabel", {
            Text = ncfg.Title or "Notification",
            Size = UDim2.new(1,-54,1,0), Position = UDim2.new(0,42,0,0),
            BackgroundTransparency = 1, TextColor3 = Theme.Text,
            Font = Theme.FontBold, TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            ZIndex = 203, Parent = Header,
        })

        if ncfg.Message then
            New("TextLabel", {
                Text = ncfg.Message,
                Size = UDim2.new(1,-26,0,32), Position = UDim2.new(0,14,0,NOTIF_HEADER_H+1),
                BackgroundTransparency = 1, TextColor3 = Theme.Muted,
                Font = Theme.Font, TextSize = 10.5,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true, ZIndex = 202, Parent = Toast,
            })
        end

        local ProgTrack = New("Frame", {
            Size = UDim2.new(1,0,0,3), Position = UDim2.new(0,0,1,-3),
            BackgroundColor3 = Theme.Surface3, BorderSizePixel = 0,
            ZIndex = 203, Parent = Toast,
        })
        local ProgFill = New("Frame", {
            Size = UDim2.new(1,0,1,0), BackgroundColor3 = tc,
            BorderSizePixel = 0, ZIndex = 204, Parent = ProgTrack,
        })

        -- ── Floating pill: player headshot + username, sitting right above
        -- the toast like a little nameplate (sibling of Toast so it isn't
        -- clipped, but it moves and fades in lockstep with it).
        local PILL_W, PILL_H, PILL_GAP = 112, 26, 6
        local Pill = New("Frame", {
            Size = UDim2.new(0, PILL_W, 0, PILL_H),
            AnchorPoint = Vector2.new(0,1),
            Position = UDim2.new(1, NOTIF_W+24, 1, -cardH-PILL_H-PILL_GAP),
            BackgroundColor3 = Theme.Surface2,
            BackgroundTransparency = 0.04,
            BorderSizePixel = 0, ZIndex = 200, Parent = Gui,
        })
        Corner(13, Pill)
        Stroke(Theme.Border, 1, Pill)
        local PillAvatar = New("ImageLabel", {
            Size = UDim2.new(0,18,0,18), Position = UDim2.new(0,5,0.5,-9),
            BackgroundColor3 = Theme.Surface3, BorderSizePixel = 0,
            Image = avatarUrl, ZIndex = 201, Parent = Pill,
        })
        Corner(9, PillAvatar)
        Stroke(Theme.Border2, 1, PillAvatar)
        New("TextLabel", {
            Text = displayName,
            Size = UDim2.new(1,-30,1,0), Position = UDim2.new(0,28,0,0),
            BackgroundTransparency = 1, TextColor3 = Theme.Muted,
            Font = Theme.Font, TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            ZIndex = 201, Parent = Pill,
        })

        local slot = {frame=Toast, pill=Pill, height=cardH}
        table.insert(_notifStack, slot)

        local bottomY = -14
        for i = #_notifStack, 1, -1 do
            local s = _notifStack[i]
            local targetPos = UDim2.new(1, _NOTIF_RIGHT - NOTIF_W, 1, bottomY - s.height)
            local pillTargetPos = UDim2.new(
                1, _NOTIF_RIGHT - PILL_W - 4,
                1, bottomY - s.height - s.height - PILL_GAP
            )
            if i == #_notifStack then
                Tween(s.frame, {Position = targetPos}, 0.32, Enum.EasingStyle.Back)
                Tween(s.pill,  {Position = pillTargetPos}, 0.32, Enum.EasingStyle.Back)
            else
                Tween(s.frame, {Position = targetPos}, 0.22)
                Tween(s.pill,  {Position = pillTargetPos}, 0.22)
            end
            bottomY = bottomY - s.height - _NOTIF_GAP
        end

        Tween(ProgFill, {Size = UDim2.new(0,0,1,0)}, dur, Enum.EasingStyle.Linear)

        local function Dismiss()
            for i, s in ipairs(_notifStack) do
                if s == slot then table.remove(_notifStack, i) break end
            end
            local by = -14
            for i = #_notifStack, 1, -1 do
                local s = _notifStack[i]
                local pillPos = UDim2.new(1, _NOTIF_RIGHT-PILL_W-4, 1, by-s.height-s.height-PILL_GAP)
                Tween(s.frame, {Position=UDim2.new(1,_NOTIF_RIGHT-NOTIF_W,1,by-s.height)}, 0.18)
                Tween(s.pill,  {Position=pillPos}, 0.18)
                by = by - s.height - _NOTIF_GAP
            end
            Tween(Toast, {Position=UDim2.new(1,NOTIF_W+24,Toast.Position.Y.Scale,Toast.Position.Y.Offset)}, 0.2)
            Tween(Pill,  {Position=UDim2.new(1,NOTIF_W+24,Pill.Position.Y.Scale,Pill.Position.Y.Offset)}, 0.2)
            task.wait(0.22) Toast:Destroy() Pill:Destroy()
        end

        Toast.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then Dismiss() end
        end)
        task.delay(dur, Dismiss)
    end

