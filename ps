-- ─── Helpers (MUST be declared before anything that calls them — Icon System,
--     below, calls New()/Tween() while building icon instances) ──────────────
local function Tween(obj, props, dur, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(dur or 0.18, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props):Play()
end

local function New(cls, props)
    local o = Instance.new(cls)
    for k, v in pairs(props) do o[k] = v end
    return o
end

local function Corner(r, parent)
    return New("UICorner", { CornerRadius = UDim.new(0, r), Parent = parent })
end
local function Stroke(color, thick, parent)
    return New("UIStroke", { Color = color, Thickness = thick or 1, Parent = parent })
end
local function Pad(l, r, t, b, parent)
    return New("UIPadding", {
        PaddingLeft   = UDim.new(0, l or 0),
        PaddingRight  = UDim.new(0, r or 0),
        PaddingTop    = UDim.new(0, t or 0),
        PaddingBottom = UDim.new(0, b or 0),
        Parent        = parent,
    })
end

-- ─── Icon System ──────────────────────────────────────────────────────────────
-- Uses the real Nebula Icon Library loader. Each icon set is lazy-loaded the
-- first time it's actually requested (so CreateWindow doesn't pay the cost of
-- downloading every icon pack up front), then cached. Pass a number instead
-- of a name (e.g. Icon = 6034509993) to use your own uploaded rbxassetid
-- image instead of a named icon.
local IconLib = nil
local _iconLibOk, _iconLibErr = pcall(function()
    IconLib = loadstring(game:HttpGet("https://raw.nebulasoftworks.xyz/nebula-icon-library-loader"))()
end)
if not _iconLibOk then
    warn("[NebulaHub] Failed to load Nebula Icon Library, icons will be blank: " .. tostring(_iconLibErr))
end

local _iconCache = {} -- "Source/name" -> assetId

local function ResolveIconId(name, source)
    source = source or "Symbols"
    local cacheKey = source .. "/" .. tostring(name)
    if _iconCache[cacheKey] ~= nil then
        return _iconCache[cacheKey]
    end
    if not IconLib then return nil end

    local ok, id = pcall(function()
        return IconLib:GetIcon(name, source)
    end)
    if ok and id then
        _iconCache[cacheKey] = id
        return id
    end
    return nil
end

local function ApplyIcon(holder, val, source, sz)
    sz = sz or 14
    for _, ch in ipairs(holder:GetChildren()) do ch:Destroy() end
    if not val then holder.Visible = false return end
    holder.Visible = true

    local assetId
    if type(val) == "number" then
        assetId = val
    else
        assetId = ResolveIconId(val, source)
    end

    if not assetId then
        -- Icon failed to resolve (lib offline / bad name) — fail quietly,
        -- don't render a broken image or block the rest of the UI.
        holder.Visible = false
        return
    end

    New("ImageLabel", {
        Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1,
        Image = "rbxassetid://" .. tostring(assetId),
        ImageColor3 = Color3.new(1,1,1),
        ScaleType = Enum.ScaleType.Fit,
        Parent = holder,
    })
end

-- Re-tints an icon holder's current glyph/image after it was already built.
local function TintIcon(holder, color, dur)
    local child = holder:FindFirstChildOfClass("TextLabel") or holder:FindFirstChildOfClass("ImageLabel")
    if not child then return end
    if child:IsA("TextLabel") then
        Tween(child, { TextColor3 = color }, dur or 0.12)
    else
        Tween(child, { ImageColor3 = color }, dur or 0.12)
    end
end

